RAW_SUB_URL=
# 以下三项为「宿主机上映射端口」：须与本机或 VPS 上已有服务不冲突；冲突时 ./clash-compose-up.sh / vps-clash-aio-bootstrap.sh 会报错退出，请改小写键名对应端口后重试。
# ALL_PROXY_PORT：宿主机端口，默认 7891 映射到容器内 mixed 7890（与 docker-compose / podman-compose 一致）。
ALL_PROXY_PORT=7891
CONTROL_PANEL_PORT=9090
# 宿主机访问 subconverter 的端口（须与 docker-compose / podman-compose 中 subconverter 映射的宿主机端口一致）
SUBCONVERTER_HOST_PORT=25500

# -----------------------------------------------------------------------------
# 可选：经 ./deploy-remote.sh 同步到 VPS 时使用（键名会随 .env 注入 clash-with-ui，Clash 会忽略；勿写 SSH 密码，建议只用密钥）
# -----------------------------------------------------------------------------
# VPS_DEPLOY_SSH_HOST=your.vps.example
# VPS_DEPLOY_SSH_PORT=22
# VPS_DEPLOY_SSH_USER=root
# VPS_DEPLOY_SSH_KEY=/path/to/id_ed25519
# VPS_DEPLOY_REMOTE_DIR=~/clash-aio-upload
# 一键脚本解压 compose 与配置的目标目录（默认 /opt/clash-aio，留空则同默认）
# VPS_DEPLOY_DEPLOY_DIR=/opt/clash-aio
# VPS 上使用 docker 或 podman（与 DEPLOYMENT.md 中 Podman 流程一致时可填 podman）
# VPS_DEPLOY_CONTAINER_ENGINE=podman
